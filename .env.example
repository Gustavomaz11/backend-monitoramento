POSTGRES_DB=navegacao_segura
POSTGRES_USER=navegacao_segura
POSTGRES_PASSWORD=change-this-local-password
POSTGRES_PORT=5432
API_PORT=8080
JWT_SIGNING_KEY=change-this-development-signing-key-with-at-least-32-chars
DATABASE_URL=postgresql://user:password@host:5432/database
ASPNETCORE_URLS=http://+:8080
Database__AutoMigrate=true
Database__SslMode=VerifyFull
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=https://frontend-monitoramento.vercel.app
